+    def get_usage_pieces(self, ctx: Context) -> list[str]:
+        """Returns the synopsis of the option if it is required.
+
+        Optional options stay hidden behind the bracketed ``[OPTIONS]``
+        placeholder, while a required one is spelled out unbracketed in the
+        usage line so it can be told apart at a glance.
+        """
+        if not self.required or self.hidden:
+            return []
+
+        def _preferred_opt(opts: cabc.Sequence[str]) -> str:
+            # Prefer the first long form, which is more descriptive than a
+            # one-letter short form.
+            return next((opt for opt in opts if opt.startswith("--")), opts[0])
+
+        piece = _preferred_opt(self.opts)
+
+        # A flag defined with an off-switch needs either of its two forms, so
+        # render them as alternatives.
+        if self.secondary_opts:
+            piece += f"|{_preferred_opt(self.secondary_opts)}"
+
+        if not self.is_flag and not self.count:
+            piece += f" {self.make_metavar(ctx=ctx)}"
+
+        if self.multiple:
+            piece += "..."
+
+        return [piece]
