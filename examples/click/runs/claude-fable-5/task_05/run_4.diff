+@pytest.mark.parametrize(
+    ("kwargs", "expected"),
+    [
+        ({}, "[OPTIONS]"),
+        ({"required": False}, "[OPTIONS]"),
+        ({"required": True}, "[OPTIONS] --foo TEXT"),
+        ({"required": True, "hidden": True}, "[OPTIONS]"),
+        ({"required": True, "type": int}, "[OPTIONS] --foo INTEGER"),
+        ({"required": True, "metavar": "BAR"}, "[OPTIONS] --foo BAR"),
+        ({"required": True, "is_flag": True}, "[OPTIONS] --foo"),
+        ({"required": True, "count": True}, "[OPTIONS] --foo"),
+        ({"required": True, "multiple": True}, "[OPTIONS] --foo TEXT..."),
+        ({"required": True, "nargs": 2}, "[OPTIONS] --foo TEXT..."),
+    ],
+)
+def test_required_option_in_usage(runner, kwargs, expected):
+    """A required option is spelled out unbracketed in the usage line, while
+    optional ones stay behind the bracketed ``[OPTIONS]`` placeholder."""
+
+    @click.command()
+    @click.option("--foo", **kwargs)
+    def cli(foo):
+        pass
+
+    result = runner.invoke(cli, ["--help"])
+    assert result.exit_code == 0
+    assert result.output.splitlines()[0] == f"Usage: cli {expected}"
+
+
+@pytest.mark.parametrize(
+    ("decls", "expected"),
+    [
+        (["--foo", "-f"], "--foo TEXT"),
+        (["-f", "--foo"], "--foo TEXT"),
+        (["-f"], "-f TEXT"),
+        (["--on/--off"], "--on|--off"),
+        (["-n/-N"], "-n|-N"),
+    ],
+)
+def test_required_option_usage_synopsis_name(runner, decls, expected):
+    """The synopsis of a required option prefers the long form and renders an
+    off-switch as an alternative."""
+
+    @click.command()
+    @click.option(*decls, required=True)
+    def cli(**kwargs):
+        pass
+
+    result = runner.invoke(cli, ["--help"])
+    assert result.exit_code == 0
+    assert result.output.splitlines()[0] == f"Usage: cli [OPTIONS] {expected}"
+
+
+def test_required_option_in_usage_with_argument(runner):
+    """Required options keep their declaration position relative to arguments
+    in the usage line."""
+
+    @click.command()
+    @click.option("--foo", required=True)
+    @click.argument("src")
+    def cli(foo, src):
+        pass
+
+    result = runner.invoke(cli, ["--help"])
+    assert result.exit_code == 0
+    assert result.output.splitlines()[0] == "Usage: cli [OPTIONS] --foo TEXT SRC"
+
+
+def test_required_group_option_in_subcommand_usage(runner):
+    """A required option of a parent group shows up in the command path of its
+    subcommands' usage lines."""
+
+    @click.group()
+    @click.option("--conf", required=True)
+    def cli(conf):
+        pass
+
+    @cli.command()
+    def sub():
+        pass
+
+    result = runner.invoke(cli, ["--conf", "x", "sub", "--help"])
+    assert result.exit_code == 0
+    assert result.output.splitlines()[0] == "Usage: cli --conf TEXT sub [OPTIONS]"
+
+
