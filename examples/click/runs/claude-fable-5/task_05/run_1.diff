+@pytest.mark.parametrize(
+    ("decls", "kwargs", "expected"),
+    [
+        (["--name"], {}, ""),
+        (["--name"], {"default": "x"}, ""),
+        (["--name"], {"required": True}, " --name TEXT"),
+        (["-n", "--name"], {"required": True}, " --name TEXT"),
+        (["--name", "-n"], {"required": True}, " --name TEXT"),
+        (["-n"], {"required": True}, " -n TEXT"),
+        (["--flag"], {"is_flag": True, "required": True}, " --flag"),
+        (["-v"], {"count": True, "required": True}, " -v"),
+        (["--name"], {"required": True, "metavar": "NAME"}, " --name NAME"),
+        (["--name"], {"required": True, "hidden": True}, ""),
+    ],
+)
+def test_required_option_in_usage(runner, decls, kwargs, expected):
+    """A required option is shown in the usage line, preferring its long form."""
+    cli = click.Command("cli", params=[click.Option(decls, **kwargs)])
+    result = runner.invoke(cli, ["--help"])
+    assert result.exit_code == 0
+    assert result.output.splitlines()[0] == f"Usage: cli [OPTIONS]{expected}"
+
+
+def test_required_options_precede_operands_in_usage(runner):
+    """Required options stay next to [OPTIONS] even when declared after
+    an argument."""
+
+    @click.command()
+    @click.argument("src")
+    @click.option("--name", required=True)
+    def cli(src, name):
+        pass
+
+    result = runner.invoke(cli, ["--help"])
+    assert result.exit_code == 0
+    assert result.output.splitlines()[0] == "Usage: cli [OPTIONS] --name TEXT SRC"
+
+
