+def test_required_option_marked_in_help(runner):
+    @click.command()
+    @click.option("--name", required=True, help="The person to greet.")
+    @click.option("--count", default=1, help="Number of greetings.")
+    def cli(name, count):
+        pass
+
+    result = runner.invoke(cli, ["--help"])
+    assert result.output.splitlines()[2:] == [
+        "Options:",
+        "  * --name TEXT      The person to greet.  [required]",
+        "    --count INTEGER  Number of greetings.",
+        "    --help           Show this message and exit.",
+    ]
+
+
+def test_no_required_options_no_marker_in_help(runner):
+    @click.command()
+    @click.option("--count", default=1, help="Number of greetings.")
+    def cli(count):
+        pass
+
+    result = runner.invoke(cli, ["--help"])
+    assert "*" not in result.output
+    assert "  --count INTEGER  Number of greetings." in result.output
+
