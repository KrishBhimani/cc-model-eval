@@ -888,6 +888,51 @@ def test_required_option(value, expect_missing, processed_value):
         assert value == processed_value
 
 
+@pytest.mark.parametrize(
+    ("decls", "kwargs", "expected"),
+    [
+        (["--name"], {}, ""),
+        (["--name"], {"required": True}, " --name TEXT"),
+        (["-n", "--name"], {"required": True}, " --name TEXT"),
+        (["-n"], {"required": True}, " -n TEXT"),
+        (["--force"], {"is_flag": True, "required": True}, " --force"),
+        (["--on/--off"], {"required": True}, " --on|--off"),
+        (["--tag"], {"multiple": True, "required": True}, " --tag TEXT..."),
+        (["--pos"], {"nargs": 2, "required": True}, " --pos TEXT..."),
+        # An option that prompts for a missing value is not required on the
+        # command line, so it is not spelled out in the usage line.
+        (["--name"], {"prompt": True, "required": True}, ""),
+        (["--name"], {"hidden": True, "required": True}, ""),
+    ],
+)
+def test_usage_line_marks_required_options(runner, decls, kwargs, expected):
+    """A required option is spelled out unbracketed in the usage line."""
+
+    @click.command()
+    @click.option(*decls, **kwargs)
+    def cli(**kwargs):
+        pass
+
+    result = runner.invoke(cli, ["--help"])
+    assert result.exit_code == 0
+    assert result.output.splitlines()[0] == f"Usage: cli [OPTIONS]{expected}"
+
+
+def test_usage_line_required_option_before_argument(runner):
+    """Required options come right after [OPTIONS], before arguments,
+    regardless of declaration order."""
+
+    @click.command()
+    @click.argument("src")
+    @click.option("--name", required=True)
+    def cli(src, name):
+        pass
+
+    result = runner.invoke(cli, ["--help"])
+    assert result.exit_code == 0
+    assert result.output.splitlines()[0] == "Usage: cli [OPTIONS] --name TEXT SRC"
+
+
