+    def get_usage_pieces(self, ctx: Context) -> list[str]:
+        """Renders a required option in the usage line, where it is shown
+        unbracketed to mark it as required, following the same convention
+        as arguments and subcommands.
+
+        An option that can prompt for a missing value does not have to be
+        given on the command line, so it stays summarized by the bracketed
+        options metavar, like all other optional options.
+        """
+        if not self.required or self.hidden or self.prompt is not None:
+            return []
+
+        def _preferred_opt(opts: cabc.Sequence[str]) -> str:
+            # Prefer the long variant since it is the most descriptive.
+            for opt in opts:
+                if len(_split_opt(opt)[0]) > 1:
+                    return opt
+
+            return opts[0]
+
+        piece = _preferred_opt(self.opts)
+
+        if self.secondary_opts:
+            piece += f"|{_preferred_opt(self.secondary_opts)}"
+
+        if not self.is_flag and not self.count:
+            piece += f" {self.make_metavar(ctx=ctx)}"
+
+        # Mark a repeatable option, unless the metavar already carries the
+        # ellipsis because of nargs.
+        if self.multiple and not piece.endswith("..."):
+            piece += "..."
+
+        return [piece]
+
