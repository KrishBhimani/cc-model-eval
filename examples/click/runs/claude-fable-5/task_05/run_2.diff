+@pytest.mark.parametrize(
+    ("decls", "kwargs", "expected"),
+    [
+        (("--name",), {}, "Usage: cli [OPTIONS]"),
+        (("--name",), {"required": True}, "Usage: cli [OPTIONS] --name TEXT"),
+        (("-n", "--name"), {"required": True}, "Usage: cli [OPTIONS] --name TEXT"),
+        (("-n",), {"required": True}, "Usage: cli [OPTIONS] -n TEXT"),
+        (
+            ("--name",),
+            {"required": True, "metavar": "ID"},
+            "Usage: cli [OPTIONS] --name ID",
+        ),
+        (
+            ("--force",),
+            {"required": True, "is_flag": True},
+            "Usage: cli [OPTIONS] --force",
+        ),
+        (
+            ("--color/--no-color",),
+            {"required": True},
+            "Usage: cli [OPTIONS] --color|--no-color",
+        ),
+        (("--name",), {"required": True, "hidden": True}, "Usage: cli [OPTIONS]"),
+    ],
+)
+def test_required_option_in_usage(runner, decls, kwargs, expected):
+    """A required option is spelled out in the usage line instead of being
+    summarized by the ``[OPTIONS]`` placeholder."""
+
+    @click.command()
+    @click.option(*decls, **kwargs)
+    def cli(**kwargs):
+        pass
+
+    result = runner.invoke(cli, ["--help"])
+    assert result.exit_code == 0
+    assert result.output.splitlines()[0] == expected
+
+
+def test_required_group_option_in_subcommand_usage(runner):
+    """A parent group's required option appears in the subcommand usage line."""
+
+    @click.group()
+    @click.option("--profile", required=True)
+    def cli(profile):
+        pass
+
+    @cli.command()
+    def sub():
+        pass
+
+    result = runner.invoke(cli, ["--profile", "x", "sub", "--help"])
+    assert result.exit_code == 0
+    assert result.output.splitlines()[0] == "Usage: cli --profile TEXT sub [OPTIONS]"
+
