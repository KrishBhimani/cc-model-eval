+def test_required_option_help_marker(runner):
+    @click.command()
+    @click.option("--name", required=True, help="Your name.")
+    @click.option("--count", default=1, help="Number of greetings.")
+    def cli(name, count):
+        pass
+
+    result = runner.invoke(cli, ["--help"])
+    lines = result.output.splitlines()
+    # The required option is prefixed with "*", the others are padded so their
+    # names stay aligned in the same column.
+    assert any(line.startswith("  * --name ") for line in lines)
+    assert any(line.startswith("    --count ") for line in lines)
+    assert any(line.startswith("    --help ") for line in lines)
+    # The old buried "[required]" tag is gone, replaced by an explanation.
+    assert "[required]" not in result.output
+    assert "Options marked with '*' are required." in result.output
+
+
+def test_no_required_option_no_marker(runner):
+    @click.command()
+    @click.option("--count", default=1, help="Number of greetings.")
+    def cli(count):
+        pass
+
+    result = runner.invoke(cli, ["--help"])
+    # With no required options, the marker column and footnote are omitted.
+    assert "  --count " in result.output
+    assert "*" not in result.output
+    assert "Options marked with" not in result.output
+
+
