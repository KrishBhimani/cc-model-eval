+def test_required_marker_precedes_help(runner):
+    """The ``[required]`` marker is shown at the start of the help text, before
+    any help and informational extras, so it lines up in a scannable column."""
+    ctx = click.Context(click.Command("cli"))
+
+    opt = click.Option(["--name"], required=True, help="Your name.")
+    assert opt.get_help_record(ctx)[1] == "[required] Your name."
+
+    # With no help text there is no stray trailing space.
+    bare = click.Option(["--bare"], required=True)
+    assert bare.get_help_record(ctx)[1] == "[required]"
+
+    # The marker leads; informational extras such as the range stay at the end.
+    leveled = click.Option(
+        ["--level"], required=True, type=click.IntRange(1, 5), help="Level."
+    )
+    assert leveled.get_help_record(ctx)[1] == "[required] Level.  [1<=x<=5]"
+
+    # Optional options gain no marker.
+    optional = click.Option(["--count"], help="How many.")
+    assert optional.get_help_record(ctx)[1] == "How many."
+
+
