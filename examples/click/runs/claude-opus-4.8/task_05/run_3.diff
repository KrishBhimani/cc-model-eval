+def test_required_options_marked_in_help(runner):
+    @click.command()
+    @click.option("--name", required=True, help="The name.")
+    @click.option("--count", default=1, help="The count.")
+    def cmd(name, count):
+        pass
+
+    result = runner.invoke(cmd, ["--help"])
+    assert not result.exception
+    # Required options get a "*" marker; others are padded to stay aligned.
+    assert "* --name" in result.output
+    assert "  --count" in result.output
+    # The redundant inline "[required]" label is replaced by the marker.
+    assert "[required]" not in result.output
+    # A legend explains the marker.
+    assert "Options marked with * are required." in result.output
+
+
+def test_no_required_marker_without_required_options(runner):
+    @click.command()
+    @click.option("--count", default=1, help="The count.")
+    def cmd(count):
+        pass
+
+    result = runner.invoke(cmd, ["--help"])
+    assert not result.exception
+    # Without required options, no marker column or legend is added.
+    assert "*" not in result.output
+    assert "Options marked with * are required." not in result.output
+
+
