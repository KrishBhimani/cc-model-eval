--- a/src/click/core.py
+++ b/src/click/core.py
@@ -3119,6 +3119,22 @@ class Option(Parameter):
                 nargs=self.nargs,
             )
 
+    def get_usage_pieces(self, ctx: Context) -> list[str]:
+        # Optional options stay collapsed into the bracketed ``[OPTIONS]``
+        # placeholder. A required option is not optional, so surface it on its
+        # own in the usage line, outside of any brackets, making it easy to see
+        # at a glance which options must be supplied.
+        if not self.required or self.hidden:
+            return []
+
+        # Prefer the long form, matching how option names are grouped elsewhere.
+        opt = max(self.opts, key=lambda o: len(_split_opt(o)[1]))
+
+        if self.is_flag or self.count:
+            return [opt]
+
+        return [f"{opt} {self.make_metavar(ctx)}"]
+
     def get_help_record(self, ctx: Context) -> tuple[str, str] | None:
         if self.hidden:
             return None
