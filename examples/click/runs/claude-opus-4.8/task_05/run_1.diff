+@pytest.mark.parametrize(
+    ("decls", "kwargs", "expected"),
+    [
+        # Optional options stay collapsed in the [OPTIONS] placeholder.
+        (["--name"], {}, "Usage: cli [OPTIONS]"),
+        (["--name"], {"required": False}, "Usage: cli [OPTIONS]"),
+        (["--flag"], {"is_flag": True}, "Usage: cli [OPTIONS]"),
+        # Required options are surfaced individually, outside the brackets.
+        (["--name"], {"required": True}, "Usage: cli [OPTIONS] --name TEXT"),
+        (["-n", "--name"], {"required": True}, "Usage: cli [OPTIONS] --name TEXT"),
+        (
+            ["--count"],
+            {"required": True, "type": int},
+            "Usage: cli [OPTIONS] --count INTEGER",
+        ),
+        (
+            ["--flag"],
+            {"is_flag": True, "required": True},
+            "Usage: cli [OPTIONS] --flag",
+        ),
+        # A required but hidden option is not shown.
+        (["--name"], {"required": True, "hidden": True}, "Usage: cli [OPTIONS]"),
+    ],
+)
+def test_required_option_in_usage(runner, decls, kwargs, expected):
+    """A required option is pulled out of the bracketed ``[OPTIONS]``
+    placeholder and shown on its own in the usage line."""
+
+    @click.command()
+    @click.option(*decls, **kwargs)
+    def cli(**_):
+        pass
+
+    result = runner.invoke(cli, ["--help"])
+    assert result.exit_code == 0
+    assert result.output.splitlines()[0] == expected
+
+
 @pytest.mark.parametrize(
     ("deprecated", "expected"),
     [(True, "(DEPRECATED)"), ("USE B INSTEAD", "(DEPRECATED: USE B INSTEAD)")],
