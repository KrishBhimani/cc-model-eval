+def test_required_help_marker_leads_help_text():
+    """The ``[required]`` marker is rendered at the start of the help text so
+    that, in a list of options, every marker lines up in the same column and
+    can be spotted at a glance.
+    """
+    option = click.Option(["--foo"], required=True, help="Some words.")
+    context = click.Context(click.Command("test"))
+    assert option.get_help_record(context)[1] == "[required] Some words."
+
+
+def test_required_help_marker_without_help_text():
+    """A required option with no help text renders only the marker, with no
+    stray leading or trailing space.
+    """
+    option = click.Option(["--foo"], required=True)
+    context = click.Context(click.Command("test"))
+    assert option.get_help_record(context)[1] == "[required]"
+
+
+def test_required_help_marker_precedes_other_extras():
+    """The required marker leads the help text while other extras such as the
+    default value remain grouped at the end.
+    """
+    option = click.Option(
+        ["--foo"], required=True, help="Words.", show_default=True, default="x"
+    )
+    context = click.Context(click.Command("test"))
+    result = option.get_help_record(context)[1]
+    assert result == "[required] Words.  [default: x]"
+
